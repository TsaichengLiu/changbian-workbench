{
  "name": "history-research-workbench",
  "version": "0.1.0",
  "private": true,
  "description": "Historical research longform workspace with project/chapter/source management.",
  "main": "electron/main.cjs",
  "type": "module",
  "scripts": {
    "dev": "concurrently -k \"vite\" \"wait-on tcp:5173 && electron electron/main.cjs\"",
    "build": "vite build",
    "preview": "vite preview",
    "start": "electron electron/main.cjs",
    "mcp:start": "node mcp/server.cjs",
    "dist:mac": "npm run build && electron-builder --mac"
  },
  "dependencies": {
    "docx": "^9.3.0",
    "opencc-js": "^1.0.5",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@types/react": "^18.3.6",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "concurrently": "^9.1.2",
    "electron": "^31.0.2",
    "electron-builder": "^24.13.3",
    "typescript": "^5.6.2",
    "vite": "^5.4.8",
    "wait-on": "^8.0.1"
  },
  "build": {
    "appId": "com.liuzecodex.historyworkbench",
    "productName": "長編工作臺",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "package.json"
    ],
    "mac": {
      "target": [
        "dmg",
        "zip"
      ],
      "category": "public.app-category.productivity"
    }
  }
}
